DB_HOST=your_production_db_host
DB_USER=your_production_db_user
DB_PASS=your_production_db_password
DB_NAME=order_db
APP_ENV=production

# Copy to .env and update with real production credentials.
# Load in PHP: Use getenv('DB_HOST') etc.
# For Apache: SetEnv DB_HOST value in .htaccess or vhost config.
# Restart server after changes.
